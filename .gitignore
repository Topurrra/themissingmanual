# Ignore everything
*

# Root-level files
!.gitignore
!.dockerignore
!docker-compose.yml
!LICENSE
!README.md

# Root-level folders
!guides/
!guides/**/*

!platform/
!platform/**/*

# --- Re-ignore generated/dependency/secret content living inside the folders
# above (the recursive un-ignores otherwise expose all of it) ---

# Rust build output
platform/target/

# Web (SvelteKit) build output + deps
platform/web/node_modules/
platform/web/.svelte-kit/
platform/web/build/
.data/
platform/.data/
platform/web/.data/
platform/web/data/
*.db
*.sqlite
*.sqlite3
.claude/
.gstack/
.cursor/
.windsurf/
.continue/
.aider*
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
.env
/dist/
/.cache/

# Maintainer-only notes, not needed in the public repo
platform/web/AGENT-DISCOVERY.md
platform/web/static/audio/README.md
!data/
data/*
!data/aisearch/
data/aisearch/*
!data/aisearch/.gitkeep
!.gitkeep
