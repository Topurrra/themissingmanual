# Public canonical origin used for absolute URLs (canonical, OpenGraph, JSON-LD).
PUBLIC_SITE_URL=https://your-domain.example

# Rust API base the SvelteKit server calls (default http://127.0.0.1:3000).
# API_BASE=http://127.0.0.1:3000

# ── Cloudflare AI Search ("Ask the guides") ───────────────────────────────────
# Preferred: manage these in the admin UI at /admin/ai-search (stored server-side
# in $ASK_DATA_DIR, never exposed via the public API). The env vars below act as
# a fallback/default when no admin config file exists yet.
# ASK_DATA_DIR=./.data        # writable dir for the AI Search SQLite DB (aisearch.db) - persist this!
#                             # requires Node 22.5+ (node:sqlite); falls back to in-memory otherwise
# CF_ACCOUNT_ID=
# CF_AISEARCH_NAME=
# CF_API_TOKEN=
# CF_AISEARCH_MONTHLY_CAP=18000
